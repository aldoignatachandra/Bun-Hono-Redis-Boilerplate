{
  "app": {
    "name": "bun-hono-kafka-cqrs",
    "version": "1.0.0"
  },
  "database": {
    "pool": {
      "min": 1,
      "max": 10,
      "idleTimeoutMs": 10000
    }
  },
  "auth": {
    "jwt": {
      "secret": "${JWT_SECRET}",
      "expiresIn": "1d"
    }
  },
  "redis": {
    "host": "${REDIS_HOST}",
    "port": "${REDIS_PORT}",
    "password": "${REDIS_PASSWORD}",
    "db": "${REDIS_DB}",
    "keyPrefix": "",
    "streams": {
      "maxLen": 10000,
      "blockMs": 5000
    }
  },
  "logging": {
    "level": "info",
    "pretty": true
  },
  "metrics": {
    "enabled": false,
    "collectDefaultMetrics": false,
    "prefix": "cqrs_",
    "buckets": [0.01, 0.05, 0.1, 0.5, 1, 5, 10]
  },
  "security": {
    "encryptionEnabled": false,
    "keyRotationInterval": 0,
    "auditLogging": false,
    "systemAuth": {
      "username": "${SYSTEM_USER}",
      "password": "${SYSTEM_PASS}"
    }
  },
  "features": {
    "hotReload": true,
    "autoMigrate": true,
    "debugMode": true
  }
}
