# -----------------------------------------------------------------------------
# Auth Service Environment Configuration
# -----------------------------------------------------------------------------

# NODE_ENV: Application environment (dev, staging, prod)
NODE_ENV=dev

# PORT: The port this service listens on
PORT=3100

# LOG_LEVEL: Logging verbosity (debug, info, warn, error)
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# URL: Connection string for PostgreSQL
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?schema=[schema]
DB_URL=postgresql://postgres:postgres@localhost:5432/cqrs_demo_dev?schema=public

# Optional: Connection pool settings
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=20
DB_CONNECTION_TIMEOUT=10

# -----------------------------------------------------------------------------
# Auth Configuration
# -----------------------------------------------------------------------------
# JWT_SECRET: Secret key for signing JWT tokens (Must be strong in production)
JWT_SECRET=your-secret-key-change-in-production

# SYSTEM_USER / SYSTEM_PASS: Basic Auth credentials for internal system routes (e.g. /admin/health)
SYSTEM_USER=admin
SYSTEM_PASS=change-this-password-in-production

# -----------------------------------------------------------------------------
# Kafka Configuration
# -----------------------------------------------------------------------------
# BROKERS: Comma-separated list of Kafka brokers (Cluster Mode)
# Example for cluster: localhost:19092,localhost:29092
KAFKA_BROKERS=localhost:19092,localhost:29092

# KAFKA_CLIENT_ID: Client identifier for Kafka
KAFKA_CLIENT_ID=service-auth

# KAFKA_USERNAME: SASL Username (Required for production)
KAFKA_USERNAME=

# KAFKA_PASSWORD: SASL Password (Required for production)
KAFKA_PASSWORD=
