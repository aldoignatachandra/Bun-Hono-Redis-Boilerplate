{
  "database": {
    "url": "postgresql://postgres:postgres@localhost:5432/cqrs_demo_dev?schema=public"
  },
  "services": {
    "userService": {
      "port": "${PORT}"
    },
    "productService": {
      "port": 3102
    }
  },
  "redis": {
    "host": "localhost",
    "port": 6379,
    "password": "",
    "db": 0,
    "keyPrefix": "user:",
    "streams": {
      "maxLen": 10000,
      "blockMs": 5000
    }
  },
  "logging": {
    "level": "debug",
    "pretty": true
  },
  "features": {
    "hotReload": true,
    "autoMigrate": true,
    "debugMode": true,
    "mockExternalServices": true
  }
}
