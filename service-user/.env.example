# -----------------------------------------------------------------------------
# User Service Environment Configuration
# -----------------------------------------------------------------------------

# NODE_ENV: Application environment (dev, staging, prod)
NODE_ENV=dev

# PORT: The port this service listens on
PORT=3101

# LOG_LEVEL: Logging verbosity
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# DB_URL: Connection string for PostgreSQL
DB_URL="postgresql://postgres:postgres@localhost:5432/cqrs_demo_dev?schema=public"

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# JWT_SECRET: Must match the secret used in other services for validation
JWT_SECRET="dev-secret-change-me-in-prod"

# -----------------------------------------------------------------------------
# Kafka Configuration
# -----------------------------------------------------------------------------
# KAFKA_BROKERS: List of Kafka brokers
KAFKA_BROKERS="localhost:19092,localhost:29092"

# KAFKA_CLIENT_ID: Unique identifier for this service in Kafka
KAFKA_CLIENT_ID="service-user"

# KAFKA_GROUP_ID: Consumer group ID for this service
KAFKA_GROUP_ID="service-user-group"
