{
  "database": {
    "url": "postgresql://postgres:postgres@staging-db:5432/cqrs_demo_staging?schema=public"
  },
  "services": {
    "userService": {
      "port": 3101
    },
    "productService": {
      "port": "${PORT}"
    }
  },
  "redis": {
    "host": "${REDIS_HOST}",
    "port": "${REDIS_PORT}",
    "password": "${REDIS_PASSWORD}",
    "db": "${REDIS_DB}",
    "keyPrefix": "product:",
    "streams": {
      "maxLen": 50000,
      "blockMs": 5000
    }
  },
  "logging": {
    "level": "info",
    "pretty": false
  },
  "metrics": {
    "enabled": true,
    "collectDefaultMetrics": true,
    "prefix": "cqrs_staging_",
    "buckets": [0.005, 0.01, 0.05, 0.1, 0.5, 1, 5, 10]
  },
  "security": {
    "encryptionEnabled": true,
    "keyRotationInterval": 604800000,
    "auditLogging": true
  },
  "features": {
    "hotReload": false,
    "autoMigrate": false,
    "debugMode": false,
    "mockExternalServices": false
  }
}
