# -----------------------------------------------------------------------------
# User Service Environment Configuration
# -----------------------------------------------------------------------------

# NODE_ENV: Application environment (dev, staging, prod)
NODE_ENV=dev

# LOG_LEVEL: Logging verbosity (debug, info, warn, error)
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# DB_URL: Connection string for PostgreSQL
DB_URL="postgresql://postgres:postgres@localhost:5432/cqrs_demo_dev?schema=public"
# DB_POOL_MAX: Maximum number of connections in the pool
DB_POOL_MAX=20
# DB_IDLE_TIMEOUT: Idle timeout in seconds before closing connection
DB_IDLE_TIMEOUT=20
# DB_CONNECTION_TIMEOUT: Connection timeout in seconds
DB_CONNECTION_TIMEOUT=10

# -----------------------------------------------------------------------------
# Auth Configuration
# -----------------------------------------------------------------------------
# JWT_SECRET: Secret key for signing JWT tokens (min 32 bytes)
JWT_SECRET="dev-secret-change-me-in-prod"

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# Service Configuration
# -----------------------------------------------------------------------------
# PORT: The port this service listens on (overrides config/base.json)
USER_SERVICE_PORT=3101
# USER_SERVICE_URL: Internal URL for service-to-service communication
USER_SERVICE_URL=http://localhost:3101
# AUTH_SERVICE_URL: Auth service URL for internal calls
AUTH_SERVICE_URL=http://localhost:3100
# PRODUCT_SERVICE_URL: Product service URL for internal calls
PRODUCT_SERVICE_URL=http://localhost:3102

# -----------------------------------------------------------------------------
# System Authentication
# -----------------------------------------------------------------------------
# SYSTEM_USER: Username for internal service-to-service calls
SYSTEM_USER="admin"
# SYSTEM_PASS: Password for internal service-to-service calls
SYSTEM_PASS="admin123"

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# CORS_ALLOWED_ORIGINS: Comma-separated list of allowed origins
# Leave empty or set to * for development (allows all origins)
# In production, set to specific origins: https://yourdomain.com,https://admin.yourdomain.com
CORS_ALLOWED_ORIGINS=*
