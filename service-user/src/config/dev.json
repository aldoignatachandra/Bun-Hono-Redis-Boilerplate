{
  "database": {
    "url": "postgresql://postgres:postgres@localhost:5432/cqrs_demo_dev?schema=public"
  },
  "services": {
    "userService": {
      "port": "${PORT}"
    },
    "productService": {
      "port": 3102
    }
  },
  "redis": {
    "host": "${REDIS_HOST}",
    "port": "${REDIS_PORT}",
    "password": "${REDIS_PASSWORD}",
    "db": "${REDIS_DB}",
    "keyPrefix": "",
    "streams": {
      "maxLen": 10000,
      "blockMs": 5000
    }
  },
  "logging": {
    "level": "debug",
    "pretty": true
  },
  "features": {
    "hotReload": true,
    "autoMigrate": true,
    "debugMode": true,
    "mockExternalServices": true
  }
}
