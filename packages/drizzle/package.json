{
  "name": "@cqrs/drizzle",
  "version": "1.0.0",
  "description": "Drizzle ORM schema and migrations for CQRS microservices",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/migrations/drizzle-migrate.ts",
    "migrate:all": "tsx src/migrations/drizzle-migrate.ts",
    "migrate:one": "tsx src/migrations/migration-manager.ts up --steps=1",
    "migrate:create": "tsx src/migrations/migration-manager.ts create",
    "migrate:down:one": "tsx src/migrations/migration-manager.ts down --steps=1",
    "migrate:status": "tsx src/migrations/migration-manager.ts status",
    "migrate:rollback": "tsx src/migrations/rollback-manager.ts rollback",
    "migrate:reset": "tsx src/migrations/migration-manager.ts reset",
    "migrate:run": "tsx src/migrations/migration-runner.ts run",
    "migrate:validate": "tsx src/migrations/migration-runner.ts validate",
    "migrate:summary": "tsx src/migrations/migration-runner.ts summary",
    "migrate:health": "tsx src/migrations/migration-runner.ts health",
    "migrate:preview": "tsx src/migrations/rollback-manager.ts preview",
    "migrate:history": "tsx src/migrations/rollback-manager.ts history",
    "migrate:test": "tsx src/migrations/test-migration-system.ts",
    "db:seed": "tsx src/seeding/seed-cli.ts run",
    "db:seed:dev": "NODE_ENV=dev tsx src/seeding/seed-cli.ts run",
    "db:seed:staging": "NODE_ENV=staging tsx src/seeding/seed-cli.ts run",
    "db:seed:prod": "NODE_ENV=prod tsx src/seeding/seed-cli.ts run",
    "db:seed:test": "NODE_ENV=test tsx src/seeding/seed-cli.ts run",
    "db:seed:reset": "tsx src/seeding/seed-cli.ts run --reset",
    "db:seed:dry-run": "tsx src/seeding/seed-cli.ts run --dry-run",
    "db:seed:clear": "tsx src/seeding/seed-cli.ts clear",
    "db:seed:clear:users": "tsx src/seeding/seed-cli.ts clear --tables=users",
    "db:seed:clear:products": "tsx src/seeding/seed-cli.ts clear --tables=products",
    "db:seed:clear:events": "tsx src/seeding/seed-cli.ts clear --tables=events",
    "db:seed:restore": "tsx src/seeding/seed-cli.ts restore",
    "db:seed:restore:all": "tsx src/seeding/seed-cli.ts restore --tables=users,products,events",
    "db:seed:stats": "tsx src/seeding/seed-cli.ts stats",
    "db:seed:validate": "tsx src/seeding/seed-cli.ts validate",
    "db:seed:config:list": "tsx src/seeding/seed-cli.ts config list",
    "db:seed:config:validate": "tsx src/seeding/seed-cli.ts config validate",
    "db:seed:help": "tsx src/seeding/seed-cli.ts help",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:check": "drizzle-kit check",
    "test": "bun test",
    "lint": "bunx eslint src --ext .ts",
    "lint:fix": "bunx eslint src --ext .ts --fix"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.7",
    "postgres": "^3.4.3",
    "@types/pg": "^8.10.9",
    "bcrypt": "^5.1.1",
    "uuid": "^9.0.1",
    "dotenv": "^16.3.1",
    "pino": "^8.17.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.7",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "bun-types": "latest",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0"
  }
}
