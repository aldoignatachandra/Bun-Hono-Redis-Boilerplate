# -----------------------------------------------------------------------------
# Global Environment Configuration
# -----------------------------------------------------------------------------
# NODE_ENV: Application environment (dev, staging, prod)
NODE_ENV=dev

# LOG_LEVEL: Logging verbosity (debug, info, warn, error)
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
# DB_URL: Connection string for the PostgreSQL database
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DB_URL="postgresql://postgres:postgres@localhost:5432/cqrs_demo_dev?schema=public"

# -----------------------------------------------------------------------------
# Authentication Secrets
# -----------------------------------------------------------------------------
# JWT_SECRET: Secret key for signing JSON Web Tokens.
# IMPORTANT: Use a strong, long random string in production.
JWT_SECRET="dev-secret-change-me-in-prod"

# -----------------------------------------------------------------------------
# Kafka Configuration (Message Broker)
# -----------------------------------------------------------------------------
# KAFKA_BROKERS: Comma-separated list of Kafka broker addresses
KAFKA_BROKERS="localhost:19092,localhost:29092"

# Optional: SASL Authentication (if enabled on brokers)
KAFKA_USERNAME=""
KAFKA_PASSWORD=""

# -----------------------------------------------------------------------------
# Service Ports (Orchestration)
# -----------------------------------------------------------------------------
# Ports for individual microservices when running locally or via docker-compose
AUTH_SERVICE_PORT=3100
USER_SERVICE_PORT=3101
PRODUCT_SERVICE_PORT=3102

# -----------------------------------------------------------------------------
# Development Tools & MCP
# -----------------------------------------------------------------------------
# GITHUB_PERSONAL_ACCESS_TOKEN: Token for GitHub MCP tools (optional)
GITHUB_PERSONAL_ACCESS_TOKEN=

# METRICS_ENABLED: Enable Prometheus metrics endpoint (true/false)
METRICS_ENABLED=false
