# -----------------------------------------------------------------------------
# Product Service Environment Configuration
# -----------------------------------------------------------------------------

# NODE_ENV: Application environment (dev, staging, prod)
NODE_ENV=dev

# LOG_LEVEL: Logging verbosity (debug, info, warn, error)
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# DB_URL: Connection string for PostgreSQL
DB_URL="postgresql://postgres:postgres@localhost:5432/cqrs_demo_dev?schema=public"

# -----------------------------------------------------------------------------
# Auth Configuration
# -----------------------------------------------------------------------------
# JWT_SECRET: Secret key for signing JWT tokens
JWT_SECRET="dev-secret-change-me-in-prod"

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# Service Configuration
# -----------------------------------------------------------------------------
# PORT: The port this service listens on (overrides config/base.json)
PRODUCT_SERVICE_PORT=3102

# -----------------------------------------------------------------------------
# System Authentication
# -----------------------------------------------------------------------------
# SYSTEM_USER: Username for internal service-to-service calls
SYSTEM_USER="admin"
# SYSTEM_PASS: Password for internal service-to-service calls
SYSTEM_PASS="admin123"
